package umari:command@0.1.0;

/// Core types for the command system
interface types {
    use umari:common/types@0.1.0.{deserialize-event-error, event-type, json};

    /// Emitted event from command execution
    record emitted-event {
        /// Event type identifier
        event-type: event-type,
        /// Event payload as JSON
        data: json,
        /// Domain IDs for event routing (field name -> value)
        domain-ids: list<tuple<string, option<string>>>,
    }

    /// Output from command execution
    record execute-output {
        /// Events to be persisted
        events: list<emitted-event>,
    }

    variant error {
        command(string),
        deserialize-event(deserialize-event-error),
        deserialize-input(string),
        serialize-event(string),
    }
}

interface execute {
    use umari:common/types@0.1.0.{stored-event, json, uuid};
    use types.{error as command-error};

    variant error {
        command(command-error),
        command-not-found,
        invalid-correlation-id,
        invalid-causation-id,
        invalid-triggered-by-id,
        serialize-input(string),
    }

    record command-context {
        command-id: option<uuid>,
        correlation-id: option<uuid>,
        triggered-by: option<uuid>,
    }
    
    execute: func(command: string, input: json, context: command-context) -> result<list<stored-event>, error>;
}

/// The command world - what a command module must implement
world command {
    use types.{error, execute-output};
    use umari:common/types@0.1.0.{dcb-query, json, stored-event};

    /// Build a query from command input to fetch relevant events
    /// This determines what events need to be loaded from the event store
    export query: func(input: json) -> result<dcb-query, error>;

    /// Execute the command with input and fetched events
    /// Returns events to be emitted/persisted
    export execute: func(input: json, events: list<stored-event>) -> result<execute-output, error>;
}
